# YDY Trend — örnek environment (gerçek secret değerleri buraya yazmayın)
# Kopyalayın: cp .env.example .env

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL="mysql://user:password@127.0.0.1:3306/ydytrend"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Production: en az 32 karakter rastgele secret
JWT_SECRET=""
# Opsiyonel — çok domain/subdomain cookie paylaşımı
# COOKIE_DOMAIN=
# Reverse proxy arkasında X-Forwarded-For güvenilirse: TRUST_PROXY=1

# ── Mail (SMTP admin panelden DB Setting olarak da yönetilir) ────────────────
# Uygulama kodu SMTP'yi veritabanından okur; aşağıdakiler opsiyonel referans.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# ── Upload / CDN ─────────────────────────────────────────────────────────────
CDN_BASE_URL="https://cdn.ornek.com"
CDN_UPLOAD_URL="https://cdn.ornek.com/upload.php"
CDN_UPLOAD_TOKEN=""
# MAX_UPLOAD_SIZE uygulama kodunda route bazlı tanımlıdır (ör. return upload 5MB)

# ── Redis (rate limit — production'da önerilir) ──────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379
# veya:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ── Brand (opsiyonel override) ───────────────────────────────────────────────
# NEXT_PUBLIC_BRAND_NAME=YDY Trend
# BRAND_SUPPORT_EMAIL=destek@ornek.com
# BRAND_PHONE=
# BRAND_WHATSAPP=

# ── PayTR (kart ödemesi) ─────────────────────────────────────────────────────
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
PAYTR_TEST_MODE=1

# ── Havale (admin panel / Setting tablosundan da yönetilebilir) ───────────────
# BANK_NAME=
# BANK_IBAN=
# BANK_ACCOUNT_HOLDER=

# ── SEO / indexing ───────────────────────────────────────────────────────────
# Production: true veya 1 — staging/test: false
# ALLOW_INDEXING=true

# ── Analytics (opsiyonel) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ── Monitoring (opsiyonel) ─────────────────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=info

# ── Cron / internal jobs (opsiyonel) ───────────────────────────────────────
# CRON_SECRET=
# EMAIL_OUTBOX_BATCH_SIZE=25
# EMAIL_OUTBOX_MAX_ATTEMPTS=5
# EMAIL_OUTBOX_RETRY_MINUTES=5
# UPLOAD_CLEANUP_DRY_RUN=true
# UPLOAD_CLEANUP_MIN_AGE_HOURS=24

# ── WooCommerce import (yalnızca script) ─────────────────────────────────────
WOO_BASE_URL="https://ornek-siteniz.com"
WOO_CONSUMER_KEY=""
WOO_CONSUMER_SECRET=""

# ── Admin CLI (scripts/create-admin.ts) ──────────────────────────────────────
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=
