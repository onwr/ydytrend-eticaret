generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  CASH_ON_DELIVERY
  BANK_TRANSFER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  CANCELLATION_RESTORE
  EXCHANGE_IN
  EXCHANGE_OUT
}

/// Stok hareketi ve rapor kanalı: web checkout ONLINE, mağaza POS RETAIL.
enum SalesChannel {
  ONLINE
  RETAIL
}

enum StoreSaleStatus {
  COMPLETED
  VOIDED
}

/// Mağaza kasasında ödeme tipi (Order.PaymentMethod’dan ayrı).
enum StorePaymentMethod {
  CASH
  CARD
  POS_CARD
}

enum HomeSectionType {
  CATEGORY
  PRODUCT_LIST
}

enum ReturnRequestType {
  RETURN
  EXCHANGE
  CANCELLATION
}

enum ReturnRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAITING_FOR_PRODUCT
  PRODUCT_RECEIVED
  COMPLETED
  CANCELLED
}

enum ReturnResolution {
  REFUND
  EXCHANGE
  STORE_CREDIT
}

enum ReturnItemCondition {
  SELLABLE
  DAMAGED
  NEEDS_INSPECTION
}

enum RefundStatus {
  NOT_REQUIRED
  PENDING
  MANUAL_PROCESSING
  COMPLETED
  FAILED
}

enum OrderStatusHistorySource {
  CUSTOMER
  ADMIN
  SYSTEM
}

enum NewsletterStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  passwordHash        String
  phone               String?
  role                UserRole             @default(CUSTOMER)
  isActive            Boolean              @default(true)
  emailVerified       Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addresses           Address[]
  orders              Order[]
  cart                Cart?
  favorites           Favorite[]
  reviews             Review[]
  passwordResetTokens PasswordResetToken[]
  adminActivities     AdminActivity[]
  returnRequests      ReturnRequest[]
  storeSalesCreated   StoreSale[]          @relation("StoreSaleCreatedBy")
  storeSalesVoided    StoreSale[]          @relation("StoreSaleVoidedBy")
}

/// Yönetim paneli işlem günlüğü (append-only).
model AdminActivity {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  actorUserId  Int?
  actorEmail   String   @db.VarChar(255)
  action       String   @db.VarChar(80)
  resourceType String?  @db.VarChar(80)
  resourceId   String?  @db.VarChar(255)
  metadata     Json?
  ip           String?  @db.VarChar(45)
  actor        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([actorUserId])
  @@index([resourceType, resourceId, createdAt])
}

/// Şifre sıfırlama: URL’deki ham token DB’de SHA-256 ile saklanır.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @db.VarChar(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Address {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  fullName    String
  phone       String
  line1       String
  line2       String?
  district    String
  city        String
  postalCode  String
  country     String   @default("TR")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingFor  Order[]  @relation("BillingAddress")
  shippingFor Order[]  @relation("ShippingAddress")

  @@index([userId])
}

model Category {
  id                 Int                  @id @default(autoincrement())
  name               String
  slug               String               @unique
  description        String?
  imageUrl           String?              @db.VarChar(500)
  parentId           Int?
  showOnHome         Boolean              @default(false)
  sortOrder          Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  parent             Category?            @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children           Category[]           @relation("CategoryTree")
  products           Product[]            @relation("MainCategory")
  homeSections       HomeProductSection[]
  subProducts        Product[]            @relation("SubCategory")
  productLinks       ProductCategory[]
  categoryAttributes CategoryAttribute[]

  @@index([parentId])
}

model Product {
  id                 Int                     @id @default(autoincrement())
  /// WooCommerce ürün kimliği; import scripti tekrar çalıştırmada eşleştirme için.
  wooProductId       Int?                    @unique
  name               String
  slug               String                  @unique
  description        String?                 @db.Text
  shortDescription   String?                 @db.Text
  categoryId         Int?
  subCategoryId      Int?
  basePrice          Decimal                 @db.Decimal(10, 2)
  compareAtPrice     Decimal?                @db.Decimal(10, 2)
  sku                String?                 @unique
  barcode            String?                 @unique
  isActive           Boolean                 @default(true)
  isFeatured         Boolean                 @default(false)
  taxRate            Int                     @default(20)
  isTaxIncluded      Boolean                 @default(true)
  metaTitle          String?
  metaDescription    String?                 @db.VarChar(500)
  /// compareAtPrice ve basePrice'tan hesaplanan indirim yüzdesi (0–100)
  discountPercentage Decimal?                @db.Decimal(5, 2)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  category           Category?               @relation("MainCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  subCategory        Category?               @relation("SubCategory", fields: [subCategoryId], references: [id], onDelete: SetNull)
  images             ProductImage[]
  variants           ProductVariant[]
  orderItems         OrderItem[]
  stockMovements     StockMovement[]
  cartItems          CartItem[]
  categories         ProductCategory[]
  favorites          Favorite[]
  reviews            Review[]
  attributeValues    ProductAttributeValue[]

  @@index([categoryId])
  @@index([isActive, createdAt])
}

model ProductCategory {
  id         Int      @id @default(autoincrement())
  productId  Int
  categoryId Int
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  url       String   @db.VarChar(500)
  alt       String?
  sortOrder Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id                Int                            @id @default(autoincrement())
  productId         Int
  name              String
  sku               String                         @unique
  price             Decimal                        @db.Decimal(10, 2)
  compareAtPrice    Decimal?                       @db.Decimal(10, 2)
  stock             Int                            @default(0)
  attributesJson    String?
  isActive          Boolean                        @default(true)
  lowStockThreshold Int                            @default(5)
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  /// Deterministik kombinasyon anahtarı: "attrId1:valId1|attrId2:valId2" (sıralı)
  /// Aynı ürün için aynı kombinasyon tekrar oluşturulamaz.
  combinationKey    String?                        @db.VarChar(500)
  imageUrl          String?                        @db.VarChar(500)
  product           Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]
  stockMovements    StockMovement[]
  cartItems         CartItem[]
  attributeValues   ProductVariantAttributeValue[]

  @@unique([productId, combinationKey])
  @@index([productId, isActive])
}

/// Üye sepeti: `userId` dolu. Misafir sepeti: `guestToken` dolu (httpOnly çerez).
model Cart {
  id         Int        @id @default(autoincrement())
  userId     Int?       @unique
  guestToken String?    @unique @db.VarChar(64)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
}

model CartItem {
  id        Int             @id @default(autoincrement())
  cartId    Int
  productId Int
  variantId Int?
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

/// Misafir siparişte `userId` null; teslimat/fatura metni sipariş anında snapshot olarak saklanır.
model Order {
  id                    Int                  @id @default(autoincrement())
  userId                Int?
  orderNo               String               @unique
  status                OrderStatus          @default(PENDING)
  paymentStatus         PaymentStatus        @default(PENDING)
  subtotal              Decimal              @db.Decimal(10, 2)
  shippingCost          Decimal              @default(0) @db.Decimal(10, 2)
  discountTotal         Decimal              @default(0) @db.Decimal(10, 2)
  grandTotal            Decimal              @db.Decimal(10, 2)
  profit                Decimal?             @db.Decimal(10, 2)
  note                  String?
  guestEmail            String?              @db.VarChar(255)
  guestPhone            String?              @db.VarChar(40)
  shippingFullName      String               @db.VarChar(200)
  shippingPhone         String               @db.VarChar(40)
  shippingLine1         String               @db.VarChar(255)
  shippingLine2         String?              @db.VarChar(255)
  shippingDistrict      String               @db.VarChar(120)
  shippingCity          String               @db.VarChar(120)
  shippingPostalCode    String               @db.VarChar(20)
  shippingCountry       String               @default("TR") @db.VarChar(2)
  billingSameAsShipping Boolean              @default(true)
  billingFullName       String?              @db.VarChar(200)
  billingPhone          String?              @db.VarChar(40)
  billingLine1          String?              @db.VarChar(255)
  billingLine2          String?              @db.VarChar(255)
  billingDistrict       String?              @db.VarChar(120)
  billingCity           String?              @db.VarChar(120)
  billingPostalCode     String?              @db.VarChar(20)
  billingCountry        String?              @db.VarChar(2)
  billingAddressId      Int?
  shippingAddressId     Int?
  cancelledAt           DateTime?
  stockRestoredAt       DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User?                @relation(fields: [userId], references: [id], onDelete: Restrict)
  billingAddress        Address?             @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  shippingAddress       Address?             @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  payments              Payment[]
  shipment              Shipment?
  statusHistory         OrderStatusHistory[]
  returnRequests        ReturnRequest[]

  @@index([userId, createdAt])
  @@index([status, paymentStatus])
  @@index([status, createdAt])
}

model OrderItem {
  id                  Int                 @id @default(autoincrement())
  orderId             Int
  productId           Int
  variantId           Int?
  name                String
  sku                 String?
  unitPrice           Decimal             @db.Decimal(10, 2)
  quantity            Int
  lineTotal           Decimal             @db.Decimal(10, 2)
  /// Sipariş anındaki varyant adı snapshot'ı (varyant silinse bile okunabilir)
  variantName         String?             @db.VarChar(255)
  /// Sipariş anındaki varyant SKU snapshot'ı
  variantSku          String?             @db.VarChar(120)
  /// Sipariş anındaki tüm attribute değerleri JSON olarak: [{name, value, colorHex?}]
  variantSnapshotJson String?             @db.Text
  createdAt           DateTime            @default(now())
  order               Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant             ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: SetNull)
  returnRequestItems  ReturnRequestItem[]

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                Int           @id @default(autoincrement())
  orderId           Int
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(10, 2)
  provider          String?
  providerPaymentId String?
  paidAt            DateTime?
  receiptUrl        String?       @db.VarChar(500)
  receiptFileName   String?       @db.VarChar(255)
  receiptMimeType   String?       @db.VarChar(120)
  receiptUploadedAt DateTime?
  createdAt         DateTime      @default(now())
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
}

model Shipment {
  id                    Int       @id @default(autoincrement())
  orderId               Int       @unique
  cargoCompany          String?
  trackingNo            String?
  trackingUrl           String?   @db.VarChar(500)
  estimatedDeliveryDate DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([trackingNo])
}

model StockMovement {
  id           Int               @id @default(autoincrement())
  productId    Int
  variantId    Int?
  orderId      Int?
  type         StockMovementType
  quantity     Int
  source       String
  note         String?
  salesChannel SalesChannel?
  storeSaleId  Int?
  createdAt    DateTime          @default(now())
  product      Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  storeSale    StoreSale?        @relation(fields: [storeSaleId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([orderId, createdAt])
  @@index([storeSaleId])
  @@index([salesChannel, createdAt])
}

/// Mağaza POS fişi (web Order’dan ayrı; aynı ProductVariant stokunu kullanır).
model StoreSale {
  id              Int                @id @default(autoincrement())
  saleNo          String             @unique @db.VarChar(32)
  status          StoreSaleStatus    @default(COMPLETED)
  subtotal        Decimal            @db.Decimal(10, 2)
  discountTotal   Decimal            @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal            @db.Decimal(10, 2)
  paymentMethod   StorePaymentMethod
  note            String?            @db.VarChar(500)
  customerPhone   String?            @db.VarChar(40)
  createdByUserId Int
  voidedAt        DateTime?
  voidedByUserId  Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       User               @relation("StoreSaleCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  voidedBy        User?              @relation("StoreSaleVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  lines           StoreSaleLine[]
  stockMovements  StockMovement[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([createdByUserId])
}

model StoreSaleLine {
  id           Int       @id @default(autoincrement())
  storeSaleId  Int
  productId    Int
  variantId    Int?
  name         String    @db.VarChar(400)
  sku          String?   @db.VarChar(120)
  quantity     Int
  unitPrice    Decimal   @db.Decimal(10, 2)
  lineDiscount Decimal   @default(0) @db.Decimal(10, 2)
  lineTotal    Decimal   @db.Decimal(10, 2)
  createdAt    DateTime  @default(now())
  storeSale    StoreSale @relation(fields: [storeSaleId], references: [id], onDelete: Cascade)

  @@index([storeSaleId])
  @@index([productId])
  @@index([variantId])
}

/// Panelden yönetilen SSS; anasayfada `showOnHome` ile filtrelenir.
model Faq {
  id         Int      @id @default(autoincrement())
  category   String?  @db.VarChar(120)
  question   String   @db.VarChar(500)
  answer     String   @db.Text
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  showOnHome Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, showOnHome, sortOrder])
  @@index([category])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Coupon {
  id          Int        @id @default(autoincrement())
  code        String     @unique
  description String?
  type        CouponType
  value       Decimal    @db.Decimal(10, 2)
  minPurchase Decimal?   @db.Decimal(10, 2)
  maxDiscount Decimal?   @db.Decimal(10, 2)
  startDate   DateTime?
  endDate     DateTime?
  usageLimit  Int?
  usageCount  Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([code, isActive])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum AttributeType {
  SELECT
  COLOR
  SIZE
  MATERIAL
  TEXT
}

/// Özellik tanımı: Renk, Beden, Materyal vb.
model Attribute {
  id           Int           @id @default(autoincrement())
  name         String
  slug         String        @unique
  type         AttributeType @default(SELECT)
  /// true ise bu özellik varyant boyutu oluşturur (Renk, Beden)
  isVariant    Boolean       @default(true)
  isFilterable Boolean       @default(false)
  isRequired   Boolean       @default(false)
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  values             AttributeValue[]
  categoryAttributes CategoryAttribute[]
  productAttrValues  ProductAttributeValue[]
  variantAttrValues  ProductVariantAttributeValue[]

  @@index([isActive, sortOrder])
}

/// Bir özelliğe ait seçilebilir değer: Gold, Silver, M, L vb.
model AttributeValue {
  id          Int      @id @default(autoincrement())
  attributeId Int
  value       String
  slug        String
  colorHex    String?  @db.VarChar(7)
  imageUrl    String?  @db.VarChar(500)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attribute         Attribute                      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  productAttrValues ProductAttributeValue[]
  variantAttrValues ProductVariantAttributeValue[]

  @@unique([attributeId, slug])
  @@index([attributeId, isActive, sortOrder])
}

/// Hangi kategoride hangi özellik kullanılır
model CategoryAttribute {
  categoryId   Int
  attributeId  Int
  isRequired   Boolean @default(false)
  isVariant    Boolean @default(true)
  isFilterable Boolean @default(false)
  sortOrder    Int     @default(0)

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeId])
  @@index([categoryId])
}

/// Ürünün genel (varyant oluşturmayan) özellikleri
model ProductAttributeValue {
  id          Int @id @default(autoincrement())
  productId   Int
  attributeId Int
  valueId     Int

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute      @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  value     AttributeValue @relation(fields: [valueId], references: [id], onDelete: Restrict)

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
  @@index([valueId])
}

/// Bir varyantın hangi özellik değerlerinden oluştuğu
model ProductVariantAttributeValue {
  id          Int @id @default(autoincrement())
  variantId   Int
  attributeId Int
  valueId     Int

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute Attribute      @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  value     AttributeValue @relation(fields: [valueId], references: [id], onDelete: Restrict)

  @@unique([variantId, attributeId])
  @@index([variantId])
  @@index([attributeId])
  @@index([valueId])
}

model Review {
  id        Int          @id @default(autoincrement())
  productId Int
  userId    Int
  rating    Int          @default(5)
  comment   String       @db.Text
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId, status])
  @@index([userId])
}

model Slider {
  id                    Int      @id @default(autoincrement())
  /// split: sol metin + sağ görsel | full_image: yalnızca büyük görsel
  heroStyle             String   @default("split") @db.VarChar(20)
  badgeText             String?  @db.VarChar(200)
  title                 String?
  subtitle              String?
  buttonText            String?  @default("İncele")
  buttonLink            String?  @db.VarChar(500)
  button2Text           String?  @db.VarChar(120)
  button2Link           String?  @db.VarChar(500)
  featuresJson          String?  @db.Text
  imageUrl              String   @db.VarChar(500)
  /// full_image: mobilde gösterilecek görsel (boşsa imageUrl kullanılır)
  mobileImageUrl        String?  @db.VarChar(500)
  /// full_image: object-cover odak noktası (ör. center, top, center top)
  imageObjectPosition   String?  @default("center") @db.VarChar(50)
  linkUrl               String?  @db.VarChar(500)
  /// full_image stilinde tüm hero tıklanabilir link (boşsa linkUrl kullanılır)
  imageOnlyLink         String?  @db.VarChar(500)
  imageOnlyOpenInNewTab Boolean  @default(false)
  sortOrder             Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String?
  imageUrl  String   @db.VarChar(500)
  linkUrl   String?  @db.VarChar(500)
  position  String // top-row, middle-row, bottom-row vb.
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position, sortOrder])
}

/// Mağaza üst şerit menüsü (HomeHeader); admin /admin/menus üzerinden yönetilir.
model HeaderNavItem {
  id             Int      @id @default(autoincrement())
  label          String
  href           String
  labelUppercase Boolean  @default(true)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  openInNewTab   Boolean  @default(false)
  childrenJson   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model OrderStatusHistory {
  id              Int                      @id @default(autoincrement())
  orderId         Int
  previousStatus  OrderStatus?
  newStatus       OrderStatus
  note            String?                  @db.VarChar(500)
  source          OrderStatusHistorySource
  changedByUserId Int?
  createdAt       DateTime                 @default(now())
  order           Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model ReturnRequestCounter {
  id         Int @id @default(1)
  year       Int
  lastNumber Int @default(0)
}

model ReturnRequest {
  id              Int                 @id @default(autoincrement())
  requestNumber   String              @unique @db.VarChar(32)
  orderId         Int
  userId          Int
  type            ReturnRequestType
  status          ReturnRequestStatus @default(PENDING)
  reason          String              @db.VarChar(120)
  customerNote    String?             @db.Text
  adminNote       String?             @db.Text
  refundStatus    RefundStatus        @default(NOT_REQUIRED)
  refundAmount    Decimal?            @db.Decimal(10, 2)
  refundMethod    String?             @db.VarChar(80)
  refundReference String?             @db.VarChar(120)
  refundedAt      DateTime?
  refundNote      String?             @db.Text
  packageOpened   Boolean?
  productUsed     Boolean?
  stockRestoredAt DateTime?
  requestedAt     DateTime            @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  user            User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  items           ReturnRequestItem[]
  attachments     ReturnAttachment[]

  @@index([orderId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ReturnRequestItem {
  id                           Int                  @id @default(autoincrement())
  returnRequestId              Int
  orderItemId                  Int
  quantity                     Int
  requestedVariantId           Int?
  requestedVariantSnapshotJson String?              @db.Text
  reason                       String?              @db.VarChar(120)
  condition                    ReturnItemCondition?
  resolution                   ReturnResolution?
  createdAt                    DateTime             @default(now())
  returnRequest                ReturnRequest        @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem                    OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([returnRequestId])
  @@index([orderItemId])
}

model ReturnAttachment {
  id              Int           @id @default(autoincrement())
  returnRequestId Int
  fileUrl         String        @db.VarChar(500)
  fileName        String        @db.VarChar(255)
  mimeType        String        @db.VarChar(120)
  size            Int
  createdAt       DateTime      @default(now())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

model NewsletterSubscriber {
  id               Int              @id @default(autoincrement())
  email            String           @unique @db.VarChar(255)
  status           NewsletterStatus @default(PENDING)
  source           String           @default("homepage") @db.VarChar(80)
  consentAt        DateTime?
  confirmedAt      DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String           @unique @default(uuid()) @db.VarChar(36)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, createdAt])
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model EmailOutbox {
  id             String            @id @default(cuid())
  type           String            @db.VarChar(80)
  recipient      String            @db.VarChar(255)
  payloadJson    String            @db.Text
  status         EmailOutboxStatus @default(PENDING)
  attempts       Int               @default(0)
  maxAttempts    Int               @default(5)
  lastError      String?           @db.Text
  idempotencyKey String?           @unique @db.VarChar(120)
  nextAttemptAt  DateTime          @default(now())
  lockedAt       DateTime?
  sentAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, nextAttemptAt])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.Text
  type  String @default("string")

  @@index([key])
}

model HomeProductSection {
  id           Int             @id @default(autoincrement())
  title        String
  subtitle     String?
  type         HomeSectionType @default(CATEGORY)
  categoryId   Int?
  productsJson String?         @db.Text // specific product IDs if type is PRODUCT_LIST (e.g. "[1, 2, 3]")
  sortOrder    Int             @default(0)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
}
